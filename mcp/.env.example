# Prompt Inspector MCP Server Configuration

# Backend API base URL (required)
# Development: http://localhost:8000
# Production: https://promptinspector.io
API_BASE_URL=http://localhost:8000

# MCP Server host and port
MCP_HOST=0.0.0.0
MCP_PORT=8080

# App API Key (optional server-wide fallback)
# Used when no X-App-Key header or Authorization: Bearer token is provided per request.
# You can find your App API Key in the Prompt Inspector dashboard under App Settings.
# PMTINSP_API_KEY=your_app_api_key_here
